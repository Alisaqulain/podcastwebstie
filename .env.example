# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/bhawnamrata?retryWrites=true&w=majority

# NextAuth — use a long random string in production
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Admin credentials (Credentials provider)
ADMIN_EMAIL=admin@bhawnamrata.com
ADMIN_PASSWORD=change-me-strong-password

# Razorpay (test or live keys from Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret

# VPS local uploads — images optimized with Sharp; videos optionally transcoded with ffmpeg
# Max sizes (MB)
UPLOAD_MAX_MB=25
UPLOAD_MAX_VIDEO_MB=120

# ffmpeg binary (install on VPS: apt install ffmpeg). Override if not on PATH.
# FFMPEG_PATH=/usr/bin/ffmpeg

# Optional hero fallback when YouTube API/clips unavailable — host an MP4 under /public or /uploads
# NEXT_PUBLIC_HERO_VIDEO_URL=/uploads/videos/2026/05/your-ambient-loop.mp4
# NEXT_PUBLIC_HERO_POSTER_URL=/newlogo.jpeg

# Optional: Calendly embed for premium booking (full https Calendly scheduling URL)
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/discovery-call

# YouTube Data API v3 — powers live channel sync, cinematic backgrounds, latest episodes
# Create a key: https://console.cloud.google.com/apis/credentials — enable "YouTube Data API v3".
# YOUTUBE_API_KEY=
# Channel handle without @ (fallback list includes BHAW Namrata / BhawnaMrata variants)
# YOUTUBE_CHANNEL_HANDLE=bhawnamrata
# Optional: stable channel id if forHandle lookup fails (YouTube Studio → channel → copy id)
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxxx
# Revalidate window for YouTube API cache (seconds, min 60)
# YOUTUBE_REVALIDATE_SECONDS=300
