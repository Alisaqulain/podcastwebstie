# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/bhawnamrata?retryWrites=true&w=majority

# NextAuth — use a long random string in production
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Admin credentials (Credentials provider)
ADMIN_EMAIL=admin@bhawnamrata.com
ADMIN_PASSWORD=change-me-strong-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (test or live keys from Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret

# Optional hero video (full-screen background on home). Add public/hero.mp4 or any mp4 URL.
# NEXT_PUBLIC_HERO_VIDEO_URL=/hero.mp4
# NEXT_PUBLIC_HERO_POSTER_URL=/logo.png

# Optional: YouTube Data API v3 — powers "Latest Conversations" from the live channel when set.
# Create a key: https://console.cloud.google.com/apis/credentials — enable "YouTube Data API v3".
# If unset, the site uses MongoDB `podcasts` or `data/podcasts-seed.json`.
# YOUTUBE_API_KEY=
# Channel handle without @ (default: BHAWNamrata)
# YOUTUBE_CHANNEL_HANDLE=BHAWNamrata
